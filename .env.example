# info2action 环境变量模板
# 拷贝本文件为 .env 后填入真实值,.env 已 git-ignored
# 详细取值步骤见 docs/配置指南.md

# ── 系统鉴权(必填)──
JWT_SECRET=change-me-to-a-random-32-char-string
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
AUTH_TOKEN=your-shared-token-here

# ── LLM(必填,摘要/分类/评分/行动生成)──
# 读取顺序: 环境变量 > .env > config/config.json ai_summary.api_key(模板已置空,不要再往里填 key)
MINIMAX_API_KEY=sk-xxxxxxxx
# MINIMAX_API_BASE=https://api.minimaxi.com/anthropic/v1
# MINIMAX_MODEL=MiniMax-M2.7

# ── 微信公众号原文导出(可选,wechat-article-exporter)──
# 读取顺序: 环境变量 > .env > config/config.json wechat_exporter.auth_key(模板已置空)
# WECHAT_EXPORTER_AUTH_KEY=xxxxxxxx

# ── 邮件(必填,密码重置/邀请使用)──
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL="info2act <noreply@info2act.com>"

# ── QA 测试账号(可选,Playwright 自动登录用)──
QA_EMAIL=qa@example.com
QA_PASSWORD=xxxxxxxx

# ── Discord(可选,执行动作分发)──
DISCORD_BOT_TOKEN=your-bot-token

# ── 豆包 ASR(必填如果用 ASR 功能)──
DOUBAO_ASR_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.auc

# ── 阿里云 OSS(必填如果用 ASR 功能,音频中转用)──
ALIYUN_OSS_AK=LTAIxxxxxxxx
ALIYUN_OSS_SK=xxxxxxxxxxxxxxxx
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=your-bucket-name

# ── 语鲸订阅(必填如果用 lingowhale 抓取)──
# 浏览器登录 lingowhale.com → DevTools → Network → 任一 /api/feed/v1/* 请求 → Request Headers
LINGOWHALE_AUTH_TOKEN=eyJhbGciOi...
LINGOWHALE_ACCESS_TOKEN=eyJhbGciOi...
LINGOWHALE_UID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINGOWHALE_BID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINGOWHALE_GUEST_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twitter(可选,fetch_url 抓推文用)──
# TWITTER_AUTH_TOKEN=xxxxxxxx
# TWITTER_CT0=xxxxxxxx

# ── GitHub(可选,fetch_url 抓 GitHub 内容用)──
# GITHUB_TOKEN=ghp_xxxxxxxx

# ── Supabase 远程主库 Phase 0 POC(可选)──
# 只放服务端/本地脚本使用的 Postgres 连接串,不要放到前端环境变量。
# SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxxxxxx
# SUPABASE_REMOTE_DB_ENV=dev
# SUPABASE_REMOTE_DB_SCHEMA=remote_poc
# 服务器部署并以 Supabase 作为生产权威数据源时开启:
# INFO2ACTION_DATA_AUTHORITY=supabase
# INFO2ACTION_READ_BACKEND=supabase_poc
# 当前最终目标是 remote_only：所有生产数据都在 Supabase。
# 开启后会校验远程读、direct writers、app-state 和 Supabase Storage 都已配置。
# INFO2ACTION_STORAGE_MODE=remote_only
# 本地开发默认仍用 SQLite;确认 staging/prod 连接后再开启上面两项。
# INFO2ACTION_READ_BACKEND=sqlite
# INFO2ACTION_EVENT_READ_BACKEND=sqlite
# INFO2ACTION_FEED_READ_BACKEND=sqlite
# INFO2ACTION_STATUS_BACKEND=sqlite
# 设置为 supabase_poc 后,对应读 API 会读 Supabase POC schema
# INFO2ACTION_EVENT_READ_BACKEND=supabase_poc
# INFO2ACTION_FEED_READ_BACKEND=supabase_poc
# INFO2ACTION_STATUS_BACKEND=supabase_poc
# Runtime/app 连接优先使用 session pooler，兼容 IPv4/IPv6。
# SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
# Remote read-path cache/snapshot TTL。写入或抓取完成后代码会清进程内 cache；
# feed_snapshots 是 Supabase 内的远程 read model，不是本地数据库缓存。
# INFO2ACTION_REMOTE_CACHE_TTL_SEC=180
# INFO2ACTION_REMOTE_AUTH_CACHE_TTL_SEC=60
# INFO2ACTION_REMOTE_SNAPSHOT_TTL_SEC=1800
# Supabase 忙碌时，非 MV 的 feed live 查询最多跑多久后主动降级。
# INFO2ACTION_REMOTE_FEED_LIVE_TIMEOUT_MS=2500
# live 查询超时后，短时间熔断 search/登录态/展开等非 MV 查询，避免连续打库。
# INFO2ACTION_REMOTE_FEED_LIVE_CIRCUIT_SEC=60
# Supabase 严重过载时可临时置 1，让非 MV live 查询直接降级。
# INFO2ACTION_REMOTE_FEED_LIVE_DISABLED=0
# 仅当连接池复用到 read-only session 时再开启；默认关闭以减少每次 DB 读的额外 round trip。
# INFO2ACTION_REMOTE_DB_FORCE_WRITABLE_ON_CONNECT=0
# migration、备份、bulk import 优先使用 direct connection；若本地网络不支持 IPv6，
# direct 可能失败，应改在支持 IPv6 的服务器执行，或使用 Supabase 的 IPv4/dedicated 方案。
# SUPABASE_DB_DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
# Supabase Storage: 图片、音频、抓取缓存 HTML 等二进制/文件型内容使用。
# SUPABASE_URL=https://PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_STORAGE_BUCKET=info2action-assets
# Pipeline 写入模式：
# - sqlite_then_sync：迁移脚手架，先写 SQLite，再同步到 Supabase。
# - supabase_direct：抓取/enrich/embedding/cluster/app-state 直接写 Supabase；
#   必须同时打开下方各阶段 direct writer，否则启动会 fail fast。
# INFO2ACTION_STORAGE_MODE=sqlite_then_sync
# INFO2ACTION_PIPELINE_WRITE_MODE=sqlite_then_sync
# INFO2ACTION_PIPELINE_WRITE_MODE=supabase_direct
# 分阶段 direct writer。
# INFO2ACTION_FETCH_WRITE_BACKEND=supabase
# INFO2ACTION_ENRICH_BACKEND=supabase
# INFO2ACTION_EMBEDDING_BACKEND=supabase
# INFO2ACTION_CLUSTER_BACKEND=supabase
# INFO2ACTION_APP_STATE_BACKEND=supabase
# INFO2ACTION_ASSET_BACKEND=supabase
# INFO2ACTION_REMOTE_SYNC_AFTER_PIPELINE=0
# INFO2ACTION_REMOTE_SYNC_HOURS=6
# INFO2ACTION_REMOTE_SYNC_MAX_ITEMS=5000
# INFO2ACTION_REMOTE_SYNC_BATCH_SIZE=500
# INFO2ACTION_REMOTE_SYNC_MAX_DB_MIB=2048

# 推荐环境分层：
# - production: 指向线上 Supabase 项目。
# - staging: 单独 Supabase 项目，同 schema，可定期从 production 全量/抽样同步。
# 本地调试通过切换 SUPABASE_DB_URL / SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY 指向 staging。

# ── ASR 调度(可选,默认 5 并发)──
# ASR_INGEST_CONCURRENCY=5
# ASR_DAILY_QUOTA_HOURS=10

# ── App 部署(production 才用)──
# ENVIRONMENT=production
# APP_BASE_URL=https://your.domain.com
# CORS_ORIGINS=https://your.domain.com
# PORT=8080
